---
layout: null
---

[
	{% for post in site.posts %}
		{
			"title": "{{ post.title | escape }}",
			"category": "{{ post.category }}",
			"tags": "{{ post.tags | join: ', ' }}",
			"url": "{{ site.baseurl }}{{ post.url }}",
			"date": "{{ post.date | date: site.date_format }}",
			{% if post.author %}
			"author": "{{ post.author }}"
			{% else %}
			"author": "{{ site.author }}"
			{% endif %}
		} {% unless forloop.last %},{% endunless %}
	{% endfor %}
]
